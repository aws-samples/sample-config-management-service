{
  "name": "@shared/logger",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "scripts": {
    "build": "npm i; nest build",
    "dist": "nest build logger",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "concurrently -c \"cyan.bold,red.bold,green.bold\" \"npm:dev-*\"",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint .",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:report": "eslint . --format junit -o reports/static-code-analysis-report.xml",
    "test": "jest",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:watch": "jest  --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.2",
    "@opentelemetry/exporter-prometheus": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/exporter-zipkin": "^1.26.0",
    "@opentelemetry/instrumentation-http": "^0.53.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.39.0",
    "@opentelemetry/instrumentation-winston": "^0.39.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.3",
    "iconv-lite": "^0.6.3",
    "maskdata": "^1.3.1",
    "nest-winston": "^1.10.0",
    "reflect-metadata": "^0.2.0",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^11.1.18",
    "@tsconfig/node18": "^18.2.4",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.12",
    "@types/logfmt": "^1.2.6",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^15.1.0",
    "jest": "^29.7.0",
    "pactum": "^3.7.0",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.8.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>",
      "<rootDir>/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/coverage/.*",
      "/main.ts",
      "\\.module\\.ts$",
      "\\.config\\.ts$",
      "\\.mock\\.ts$",
      "/index.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/coverage/.*",
      "/main.ts",
      "\\.module\\.ts$",
      "\\.config\\.ts$",
      "\\.mock\\.ts$",
      "/index.ts"
    ],
    "moduleNameMapper": {}
  },
  "overrides": {
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "qs": "^6.13.0",
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0"
  }
}
