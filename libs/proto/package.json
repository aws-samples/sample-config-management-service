{
  "name": "@shared/proto",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dist": "nest build proto",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:report": "eslint . --format junit -o reports/static-code-analysis-report.xml",
    "test": "jest --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles --watchAll=false",
    "test:watch": "jest  --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {},
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>",
      "<rootDir>"
    ],
    "moduleNameMapper": {}
  },
  "overrides": {
    "qs": "^6.13.0",
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0"
  }
}