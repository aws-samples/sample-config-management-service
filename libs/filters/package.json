{
  "name": "@shared/filters",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "scripts": {
    "build": "npm i; nest build",
    "dist": "nest build filters",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:report": "eslint . --format junit -o reports/static-code-analysis-report.xml",
    "test": "jest",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {},
  "devDependencies": {},
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/coverage/.*",
      "/main.ts",
      "\\.module\\.ts$",
      "\\.config\\.ts$",
      "\\.mock\\.ts$"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/coverage/.*",
      "/main.ts",
      "\\.module\\.ts$",
      "\\.config\\.ts$",
      "\\.mock\\.ts$",
      "/index.ts"
    ],
    "roots": [
      "<rootDir>",
      "<rootDir>/"
    ],
    "moduleNameMapper": {
      "^@shared/logger(|/.*)$": "<rootDir>/../../libs/logger/src/$1",
      "^@shared/filters(|/.*)$": "<rootDir>/../../libs/filters/src/$1"
    }
  },
  "overrides": {
    "qs": "^6.13.0",
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0"
  }
}