{
  "name": "config-service",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "compile": "nest build",
    "docker:build": "docker build -t config-service .",
    "docker:run": "docker run --rm -it -p 3000:3000 config-service",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/config-service/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:update": "jest --updateSnapshot",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "upgrade": "scripts/run-task upgrade",
    "test:coverage": "jest --coverage",
    "watch": "tsc --build -w"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.614.0",
    "@aws-sdk/client-ssm": "^3.614.0",
    "@grpc/grpc-js": "^1.11.1",
    "@grpc/proto-loader": "^0.7.13",
    "aws-sdk-client-mock": "^4.0.1",
    "dynamoose": "^4.0.1",
    "ts-proto": "^1.181.1"
  },
  "version": "1.0.0",
  "publishConfig": {
    "access": "restricted"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/coverage/.*",
      "/main.ts",
      "\\.module\\.ts$",
      "\\.config\\.ts$",
      "\\.mock\\.ts$"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/coverage/.*",
      "/main.ts",
      "\\.module\\.ts$",
      "\\.config\\.ts$",
      "\\.mock\\.ts$"
    ],
    "roots": [
      "<rootDir>/",
      "<rootDir>/"
    ],
    "moduleNameMapper": {
      "^@shared/logger(|/.*)$": "<rootDir>/../../libs/logger/src/$1",
      "^@shared/filters(|/.*)$": "<rootDir>/../../libs/filters/src/$1",
      "^@shared/proto(|/.*)$": "<rootDir>/../../libs/proto/src/$1"
    }
  },
  "overrides": {
    "fast-xml-parser": "^5.3.6"
  }
}