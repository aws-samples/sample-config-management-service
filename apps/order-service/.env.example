# Order Service Configuration
NODE_ENV=dev
PORT=3001

# Config Service gRPC Endpoint
CONFIG_SERVICE_ENDPOINT=config-service-dev-alb.us-east-1.elb.amazonaws.com:5000

# AWS Configuration
AWS_REGION=us-east-1

# Cognito Configuration
COGNITO_USER_POOL_ID=us-east-1_xxxxx
COGNITO_CLIENT_ID=xxxxx

# Logging
LOG_LEVEL=info