# Config Service Environment Variables
# Copy this file to .env and update with your actual values

# DynamoDB Configuration
DYNAMO_CONFIG_TABLE=config-service-dev-configurations

# SSM Parameter Store
SSM_PATH=/config-service

# AWS Configuration
AWS_REGION=us-east-1

# Cognito Authentication (Get these from CloudFormation outputs)
# aws cloudformation describe-stacks --stack-name config-service-data --region us-east-1 --query 'Stacks[0].Outputs'
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Application Configuration
PORT=3000
GRPC_PORT=5000
NODE_ENV=dev
LOG_LEVEL=info
TRACING_ENABLED=false

# For Testing Script (infrastructure/scripts/test-local.sh)
GRPC_HOST=localhost:5000
