{
  "name": "config-service-monorepo",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "install:config-service": "cd apps/config-service && npm i",
    "install:order-service": "cd apps/order-service && npm i",
    "install:logger": "cd libs/logger && npm i",
    "install:proto": "cd libs/proto && npm i",
    "install:filters": "cd libs/filters && npm i",
    "install:auth": "cd libs/auth && npm i",
    "install:libs": "npm run install:logger && npm run install:proto && npm run install:filters && npm run install:auth",
    "start": "nest start",
    "start:config-service": "nest start config-service --debug --watch",
    "start:order-service": "nest start order-service",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/config-service-monorepo/main",
    "build:config-service": "nest build config-service",
    "build:order-service": "nest build order-service",
    "build:logger": "nest build logger",
    "build:proto": "nest build proto",
    "build:filters": "nest build filters",
    "build:auth": "nest build auth",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:logger": "cd ./libs/logger && jest --coverage",
    "test:filters": "cd ./libs/filters && jest --coverage",
    "test:auth": "cd ./libs/auth && jest --coverage",
    "test:config-service": "cd ./apps/config-service && jest --coverage",
    "test:order-service": "cd ./apps/order-service && jest --coverage",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/config-service-monorepo/test/jest-e2e.json",
    "audit": "npm audit && npm run audit:config-service && npm run audit:order-service && npm run audit:libs",
    "audit:config-service": "cd apps/config-service && npm audit",
    "audit:order-service": "cd apps/order-service && npm audit",
    "audit:libs": "npm run audit:logger && npm run audit:proto && npm run audit:filters && npm run audit:auth",
    "audit:logger": "cd libs/logger && npm audit",
    "audit:proto": "cd libs/proto && npm audit",
    "audit:filters": "cd libs/filters && npm audit",
    "audit:auth": "cd libs/auth && npm audit",
    "audit:fix": "npm audit fix && cd apps/config-service && npm audit fix && cd ../order-service && npm audit fix && cd ../../libs/logger && npm audit fix && cd ../proto && npm audit fix && cd ../filters && npm audit fix && cd ../auth && npm audit fix",
    "publish:filters": "cd ./libs/filters && npm publish",
    "publish:logger": "cd ./libs/logger && npm publish",
    "publish:auth": "cd ./libs/auth && npm publish",
    "publish:ptoto": "cd ./libs/ptoto && npm publish"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.11.1",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/core": "^11.1.19",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "nest-winston": "^1.10.0",
    "nestjs-otel": "^6.1.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.25",
    "@eslint/eslintrc": "^3.1.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^11.1.19",
    "@tsconfig/strictest": "^2.0.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-formatter-junit": "^8.40.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unused-imports": "^4.0.1",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  },
  "overrides": {
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "systeminformation": "^5.31.0",
    "lodash": "^4.17.21",
    "js-yaml": "^4.1.0",
    "qs": "^6.13.0",
    "minimatch": "^10.0.0"
  }
}